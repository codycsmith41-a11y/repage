{
  "manifest_version": 3,
  "name": "RePage - Unscroll the Internet",
  "version": "4.1",
  "description": "Eliminates infinite scroll from every website. Browse the web in pages, like reading a book. Free and open source.",
  "permissions": ["storage", "activeTab", "tabs"],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["repage.js"],
      "css": ["repage.css"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png"
    }
  }
}
